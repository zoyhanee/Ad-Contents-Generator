@dataclass
@dataclass
@dataclass
@dataclass
def _normalize_text(text: str) -> str:
    text = text.lower().strip()
    text = re.sub(r"\s+", " ", text)
    return text


def _encode_image_as_data_url(image_path: str | Path) -> str:
    path = Path(image_path)
    if not path.exists():
        raise FileNotFoundError(f"이미지 파일을 찾을 수 없습니다: {path}")

    mime_type, _ = mimetypes.guess_type(path.name)
    mime_type = mime_type or "image/png"
    encoded = base64.b64encode(path.read_bytes()).decode("utf-8")
    return f"data:{mime_type};base64,{encoded}"


def _parse_json_response(raw_text: str) -> dict:
    cleaned = raw_text.strip()
    if cleaned.startswith("```"):
        cleaned = re.sub(r"^```(?:json)?\s*", "", cleaned)
        cleaned = re.sub(r"\s*```$", "", cleaned)
    return json.loads(cleaned)

    
def build_post_evaluation_prompt(
    *,
    product_name: str,
    product_description: str | None,
    strategy: dict,
    slogan: str,
) -> str:
    """
    생성 완료된 광고를 사후 종합 평가하기 위한 프롬프트를 생성합니다.

    평가 결과는 사용자 생성 흐름에 직접 개입하지 않고,
    향후 반복 문제 분석과 생성 프롬프트 개선에 활용합니다.
    """
    strategy_text = json.dumps(
        strategy,
        ensure_ascii=False,
        indent=2,
        default=str,
    )

    return f"""
당신은 AI로 생성된 광고 콘텐츠를 평가하는 전문 평가자입니다.

제공된 상품 정보, 광고 전략, 최종 슬로건,
원본 상품 이미지와 생성된 광고 이미지를 종합적으로 평가하세요.

이 평가 결과는 향후 반복되는 생성 문제를 분석하고
광고 생성 프롬프트를 개선하는 데 사용됩니다.

따라서 다음 원칙을 지키세요.

- 제공된 정보와 이미지에서 확인할 수 있는 내용만 평가하세요.
- 확인할 수 없는 상품 특징이나 광고 효과를 추측하지 마세요.
- 단순히 좋다거나 나쁘다고 평가하지 말고 구체적인 이유를 제시하세요.
- 개선사항은 향후 생성 프롬프트에 반영할 수 있도록 구체적으로 작성하세요.


[상품 정보]

상품명:
{product_name or "미입력"}

상품 설명:
{product_description or "미입력"}


[광고 전략]

{strategy_text}


[최종 슬로건]

{slogan or "미입력"}


[이미지 입력 순서]

첫 번째 이미지:
원본 상품 이미지

두 번째 이미지:
생성된 최종 광고 이미지

두 이미지를 혼동하지 마세요.


[평가 기준]

1. slogan_quality

최종 슬로건의 광고 품질을 평가하세요.

다음을 고려하세요.

- 상품의 특징이나 가치를 적절하게 전달하는가
- 광고 문구로서 간결하고 기억하기 쉬운가
- 제공된 상품 정보에 근거하고 있는가
- 광고 전략과 자연스럽게 어울리는가

1점에서 10점으로 평가하세요.


2. visual_quality

생성된 광고 이미지 자체의 시각적 완성도를 평가하세요.

다음을 고려하세요.

- 전체적인 구성과 균형
- 시각적 주목도와 계층 구조
- 상품이 광고의 중심으로 명확하게 보이는지
- 이미지의 자연스러움과 완성도
- 광고 콘텐츠로 실제 활용 가능한 수준인지
- 눈에 띄는 왜곡이나 부자연스러운 요소가 있는지

1점에서 10점으로 평가하세요.


3. product_fidelity

첫 번째 원본 상품 이미지와
두 번째 생성 광고 이미지를 직접 비교하세요.

다음과 같은 상품의 핵심 시각적 특징이
얼마나 잘 보존되었는지 평가하세요.

- 상품 형태
- 주요 색상
- 패키지
- 로고 또는 브랜드 요소
- 원본에서 식별 가능한 특징

생성 과정에서 상품이 불필요하게 변형되거나,
사라지거나, 다른 상품처럼 변경된 경우 감점하세요.

원본 이미지에서 확인할 수 없는 특징은 추측하지 마세요.

1점에서 10점으로 평가하세요.


4. strategy_alignment

생성된 최종 광고가 제공된 광고 전략과
얼마나 잘 부합하는지 평가하세요.

제공된 경우 다음 정보를 고려하세요.

- 타겟 고객
- 광고 목표
- 플랫폼
- 광고 스타일
- 추가 테마
- 기타 전략 정보

전략에 존재하지 않는 조건을 임의로 가정하지 마세요.

1점에서 10점으로 평가하세요.


5. slogan_visual_alignment

최종 슬로건과 생성된 광고 이미지가
하나의 일관된 광고 메시지를 전달하는지 평가하세요.

다음을 고려하세요.

- 이미지의 시각적 콘셉트가 슬로건의 메시지를 지원하는가
- 슬로건이 해당 이미지와 자연스럽게 어울리는가
- 상품, 이미지 분위기와 슬로건이 서로 충돌하지 않는가
- 전체적으로 하나의 광고 콘텐츠처럼 연결되는가

1점에서 10점으로 평가하세요.


[종합 점수]

overall_score는 0점에서 100점으로 평가하세요.

다섯 평가 항목을 종합적으로 고려하되,
단순 평균만 계산하지 마세요.

상품이 심하게 변형되었거나
전략과 크게 어긋나는 등 광고의 핵심 목적을 훼손하는 문제가 있다면
종합 점수에 충분히 반영하세요.


[피드백 작성 기준]

strengths:
- 현재 결과에서 잘된 점을 구체적으로 작성하세요.
- 향후 생성에서도 유지할 가치가 있는 특징을 중심으로 작성하세요.

issues:
- 현재 결과에서 실제로 관찰되는 문제를 구체적으로 작성하세요.
- 단순히 점수가 낮다고 표현하지 말고 무엇이 문제인지 작성하세요.

improvements:
- 향후 광고 생성 프롬프트 개선에 활용할 수 있는
  구체적이고 실행 가능한 개선 방향을 작성하세요.
- 현재 이미지를 직접 수정하라는 지시가 아니라,
  다음 생성에서 어떤 조건을 강화하거나 변경해야 하는지 작성하세요.


[출력 형식]

반드시 아래 구조의 유효한 JSON만 출력하세요.

{{
  "slogan_quality": {{
    "score": 1,
    "feedback": "평가 이유"
  }},
  "visual_quality": {{
    "score": 1,
    "feedback": "평가 이유"
  }},
  "product_fidelity": {{
    "score": 1,
    "feedback": "평가 이유"
  }},
  "strategy_alignment": {{
    "score": 1,
    "feedback": "평가 이유"
  }},
  "slogan_visual_alignment": {{
    "score": 1,
    "feedback": "평가 이유"
  }},
  "overall_score": 0,
  "strengths": [
    "잘된 점"
  ],
  "issues": [
    "문제점"
  ],
  "improvements": [
    "향후 생성 프롬프트 개선 방향"
  ]
}}

JSON 외의 설명은 출력하지 마세요.
마크다운 코드 블록을 사용하지 마세요.
""".strip()

def build_ad_evaluation_request(
    *,
    db: Session,
    project_id: int,
    draft_id: int,
) -> AdEvaluationRequest:
    """
    프로젝트와 광고 시안 정보를 조회하여
    사후 종합 평가 입력을 자동 구성합니다.
    """

    project = db.get(
        AdProject,
        project_id,
    )

    if project is None:
        raise ValueError(
            f"프로젝트를 찾을 수 없습니다: project_id={project_id}"
        )

    draft = db.get(
        AdDraft,
        draft_id,
    )

    if draft is None:
        raise ValueError(
            f"광고 시안을 찾을 수 없습니다: draft_id={draft_id}"
        )

    # 다른 프로젝트의 draft를 잘못 평가하는 것을 방지
    if draft.project_id != project.id:
        raise ValueError(
            "해당 광고 시안은 요청한 프로젝트에 속하지 않습니다."
        )

    product = project.product

    if product is None:
        raise ValueError(
            f"상품 정보를 찾을 수 없습니다: project_id={project_id}"
        )

    strategy = project.strategy

    if strategy is None:
        raise ValueError(
            f"광고 전략을 찾을 수 없습니다: project_id={project_id}"
        )

    if not product.image_path:
        raise ValueError(
            "원본 상품 이미지 경로가 없습니다."
        )

    if not draft.image_path:
        raise ValueError(
            "생성 광고 이미지 경로가 없습니다."
        )

    selected_slogan = (
        strategy.selected_slogan or ""
    ).strip()

    if not selected_slogan:
        raise ValueError(
            "선택된 최종 슬로건이 없습니다."
        )

    strategy_data = {
        "selected_platforms": strategy.selected_platforms or [],
        "poster_size": strategy.poster_size,
        "selected_goal": strategy.selected_goal,
        "selected_style": strategy.selected_style,
        "strategy_title": strategy.strategy_title,
        "strategy_description": strategy.strategy_description,
    }

    return AdEvaluationRequest(
        project_id=project.id,
        draft_id=draft.id,

        product_name=product.name,
        product_description=product.description,

        product_image_path=product.image_path,

        strategy=strategy_data,

        slogan=selected_slogan,

        generated_image_path=draft.image_path,
    )

def evaluate_generated_ad(
    evaluation_input: AdEvaluationRequest,
    model: str | None = None,
) -> AdEvaluationResponse:
    """
    생성 완료된 광고를 사후 종합 평가합니다.

    이 함수는 광고 생성 과정과 분리되어 있으며,
    생성 완료 이후 평가 데이터 수집 및
    향후 프롬프트 개선을 위해 사용합니다.
    """
    try:
        from openai import OpenAI
    except ImportError as exc:
        raise RuntimeError(
            "광고 종합 평가를 사용하려면 openai 패키지가 필요합니다."
        ) from exc

    api_key = settings.OPENAI_API_KEY

    if not api_key:
        raise RuntimeError(
            "광고 종합 평가를 사용하려면 OPENAI_API_KEY가 필요합니다."
        )

    client = OpenAI(api_key=api_key)

    model_name = (
        model
        or getattr(settings, "IMAGE_EVAL_MODEL", None)
        or "gpt-5-mini"
    )

    # 1. 원본 상품 이미지
    product_image_data_url = _encode_image_as_data_url(
        evaluation_input.product_image_path
    )

    # 2. 생성된 광고 이미지
    generated_image_data_url = _encode_image_as_data_url(
        evaluation_input.generated_image_path
    )

    # 3. 사후 종합 평가 프롬프트
    evaluation_prompt = build_post_evaluation_prompt(
        product_name=evaluation_input.product_name,
        product_description=evaluation_input.product_description,
        strategy=evaluation_input.strategy,
        slogan=evaluation_input.slogan,
    )

    # 4. 멀티모달 평가 실행
    response = client.responses.create(
        model=model_name,
        input=[
            {
                "role": "user",
                "content": [
                    {
                        "type": "input_text",
                        "text": evaluation_prompt,
                    },
                    {
                        "type": "input_image",
                        "image_url": product_image_data_url,
                        "detail": "high",
                    },
                    {
                        "type": "input_image",
                        "image_url": generated_image_data_url,
                        "detail": "high",
                    },
                ],
            }
        ],
    )

    # 5. JSON 응답 파싱
    parsed = _parse_json_response(
        response.output_text
    )

    # 6. Pydantic Schema 검증 후 반환
    return AdEvaluationResponse.model_validate(
        parsed
    )

def get_existing_ad_evaluation(
    *,
    db: Session,
    draft_id: int,
) -> AdEvaluation | None:
    """
    특정 광고 시안에 대한 기존 사후 평가를 조회합니다.
    """

    stmt = select(AdEvaluation).where(
        AdEvaluation.draft_id == draft_id
    )

    return db.scalar(stmt)

def save_ad_evaluation(
    *,
    db: Session,
    project_id: int,
    draft_id: int | None,
    evaluation: AdEvaluationResponse,
) -> AdEvaluation:
    """
    사후 종합 평가 결과를 DB에 저장합니다.
    """

    ad_evaluation = AdEvaluation(
        project_id=project_id,
        draft_id=draft_id,

        slogan_quality_score=evaluation.slogan_quality.score,
        visual_quality_score=evaluation.visual_quality.score,
        product_fidelity_score=evaluation.product_fidelity.score,
        strategy_alignment_score=evaluation.strategy_alignment.score,
        slogan_visual_alignment_score=(
            evaluation.slogan_visual_alignment.score
        ),

        overall_score=evaluation.overall_score,

        feedback={
            "slogan_quality": evaluation.slogan_quality.feedback,
            "visual_quality": evaluation.visual_quality.feedback,
            "product_fidelity": evaluation.product_fidelity.feedback,
            "strategy_alignment": evaluation.strategy_alignment.feedback,
            "slogan_visual_alignment": (
                evaluation.slogan_visual_alignment.feedback
            ),
        },

        strengths=evaluation.strengths,
        issues=evaluation.issues,
        improvements=evaluation.improvements,
    )

    db.add(ad_evaluation)
    db.commit()
    db.refresh(ad_evaluation)

    return ad_evaluation

def evaluate_and_save_generated_ad(
    *,
    db: Session,
    project_id: int,
    draft_id: int,
) -> AdEvaluation:
    """
    광고 시안의 사후 평가를 실행하고 DB에 저장합니다.

    이미 평가된 draft라면 기존 평가 결과를 반환합니다.
    """

    # 1. 중복 평가 확인
    existing = get_existing_ad_evaluation(
        db=db,
        draft_id=draft_id,
    )

    if existing is not None:
        return existing

    # 2. DB 데이터로 평가 입력 자동 구성
    evaluation_input = build_ad_evaluation_request(
        db=db,
        project_id=project_id,
        draft_id=draft_id,
    )

    # 3. 멀티모달 사후 평가
    evaluation = evaluate_generated_ad(
        evaluation_input
    )

    # 4. 평가 결과 저장
    return save_ad_evaluation(
        db=db,
        project_id=project_id,
        draft_id=draft_id,
        evaluation=evaluation,
    )
    

def evaluate_project_drafts(
    *,
    db: Session,
    project_id: int,
) -> list[AdEvaluation]:
    """
    프로젝트에 속한 생성 완료 광고 시안을 사후 평가합니다.

    이미 평가된 draft는 기존 평가 결과를 사용하고,
    아직 평가되지 않은 draft만 새로 평가합니다.
    """

    project = db.get(
        AdProject,
        project_id,
    )

    if project is None:
        raise ValueError(
            f"프로젝트를 찾을 수 없습니다: project_id={project_id}"
        )

    evaluations: list[AdEvaluation] = []

    for draft in project.drafts:
        # 이미지가 없는 draft는 평가 대상에서 제외
        if not draft.image_path:
            continue

        try:
            evaluation = evaluate_and_save_generated_ad(
                db=db,
                project_id=project.id,
                draft_id=draft.id,
            )

            evaluations.append(evaluation)

        except Exception as exc:
            # 하나의 draft 평가 실패가
            # 나머지 draft 평가를 막지 않도록 처리
            print(
                f"[evaluation] "
                f"draft_id={draft.id} 평가 실패: {exc}"
            )

    return evaluations

def run_project_evaluation_background(
    project_id: int,
) -> None:
    """
    별도 DB 세션을 생성하여 프로젝트의 광고 시안을
    사후 평가합니다.

    FastAPI BackgroundTasks에서 호출하기 위한 함수입니다.
    """

    from app.db.database import SessionLocal

    db = SessionLocal()

    try:
        evaluate_project_drafts(
            db=db,
            project_id=project_id,
        )

    except Exception as exc:
        print(
            f"[evaluation] "
            f"project_id={project_id} "
            f"백그라운드 평가 실패: {exc}"
        )

    finally:
        db.close()
        

def build_evaluation_improvement_context(
    *,
    db: Session,
    limit: int = 20,
) -> dict:
    """
    최근 광고 평가 결과를 기반으로
    향후 생성 프롬프트 개선에 사용할 컨텍스트를 구성합니다.

    이 함수 자체에서는 LLM을 호출하지 않습니다.
    """

    evaluations = (
        db.query(AdEvaluation)
        .order_by(AdEvaluation.created_at.desc())
        .limit(limit)
        .all()
    )

    if not evaluations:
        return {
            "evaluation_count": 0,
            "average_scores": {},
            "issues": [],
            "improvements": [],
        }

    score_fields = [
        "slogan_quality_score",
        "visual_quality_score",
        "product_fidelity_score",
        "strategy_alignment_score",
        "slogan_visual_alignment_score",
        "overall_score",
    ]

    average_scores = {}

    for field in score_fields:
        values = [
            float(getattr(evaluation, field))
            for evaluation in evaluations
            if getattr(evaluation, field) is not None
        ]

        if values:
            average_scores[field] = round(
                sum(values) / len(values),
                2,
            )

    issues = []
    improvements = []

    for evaluation in evaluations:
        if isinstance(evaluation.issues, list):
            issues.extend(evaluation.issues)

        if isinstance(evaluation.improvements, list):
            improvements.extend(evaluation.improvements)

    # 동일한 문장이 여러 평가에 반복 저장될 수 있으므로
    # 정확히 같은 항목만 우선 제거합니다.
    issues = list(dict.fromkeys(issues))
    improvements = list(dict.fromkeys(improvements))

    return {
        "evaluation_count": len(evaluations),
        "average_scores": average_scores,
        "issues": issues,
        "improvements": improvements,
    }
    

def identify_evaluation_weak_areas(
    *,
    evaluation_context: dict,
    threshold: float = 8.0,
) -> list[dict]:
    """
    평가 평균 점수를 기반으로 개선이 필요한 영역을 식별합니다.

    점수가 낮은 영역부터 정렬하며,
    threshold 이상인 영역은 우선 개선 대상에서 제외합니다.
    """

    average_scores = evaluation_context.get(
        "average_scores",
        {}
    )

    score_mapping = {
        "slogan_quality_score": "slogan_quality",
        "visual_quality_score": "visual_quality",
        "product_fidelity_score": "product_fidelity",
        "strategy_alignment_score": "strategy_alignment",
        "slogan_visual_alignment_score": (
            "slogan_visual_alignment"
        ),
    }

    weak_areas = []

    for score_field, area in score_mapping.items():
        score = average_scores.get(score_field)

        if score is None:
            continue

        if score < threshold:
            weak_areas.append(
                {
                    "area": area,
                    "score": score,
                }
            )

    weak_areas.sort(
        key=lambda item: item["score"]
    )

    return weak_areas


def classify_evaluation_feedback(
    *,
    evaluation_context: dict,
    weak_areas: list[dict],
) -> dict:
    """
    평가 피드백을 취약 영역별로 분류합니다.

    하나의 피드백은 여러 영역과 관련될 수 있습니다.
    현재 취약 영역에 해당하는 피드백만 반환합니다.
    """

    issues = evaluation_context.get("issues", [])
    improvements = evaluation_context.get(
        "improvements",
        [],
    )

    active_areas = {
        item["area"]
        for item in weak_areas
    }

    keyword_mapping = {
        "slogan_quality": [
            "슬로건",
            "카피",
            "문구",
            "헤드라인",
            "기억",
            "간결",
            "설명형",
        ],
        "visual_quality": [
            "시각",
            "레이아웃",
            "여백",
            "텍스트",
            "구도",
            "해상도",
            "아티팩트",
            "조명",
            "배경",
        ],
        "product_fidelity": [
            "원본",
            "제품 충실",
            "디테일",
            "질감",
            "텍스처",
            "색감",
            "형상",
            "로고",
            "재질",
        ],
        "strategy_alignment": [
            "전략",
            "플랫폼",
            "인스타",
            "인스타그램",
            "배민",
            "Baemin",
            "CTA",
            "행동 유도",
            "착용 컷",
            "라이프스타일",
        ],
        "slogan_visual_alignment": [
            "텍스트",
            "문구",
            "슬로건",
            "가림",
            "배치",
            "여백",
            "제품 영역",
            "시선",
            "타이포그래피",
        ],
    }

    classified = {}

    for area in active_areas:
        classified[area] = {
            "issues": [],
            "improvements": [],
        }

    def match_areas(text: str) -> list[str]:
        matched = []

        normalized = str(text).lower()

        for area in active_areas:
            keywords = keyword_mapping.get(area, [])

            if any(
                keyword.lower() in normalized
                for keyword in keywords
            ):
                matched.append(area)

        return matched

    for issue in issues:
        for area in match_areas(issue):
            classified[area]["issues"].append(issue)

    for improvement in improvements:
        for area in match_areas(improvement):
            classified[area]["improvements"].append(
                improvement
            )

    return classified


def build_prompt_improvement_rules(
    *,
    classified_feedback: dict,
    weak_areas: list[dict],
    max_rules_per_area: int = 3,
) -> dict:
    """
    분류된 평가 피드백에서 다음 생성에 재사용하기 적합한
    범용 개선 규칙을 구성합니다.

    특정 상품명, 브랜드, 플랫폼 또는 지나치게 구체적인
    수치/레이아웃 지시는 제외합니다.
    """

    excluded_keywords = [
        # 특정 브랜드 / 상품
        "nike",
        "나이키",
        "zoomx",
        "스우시",
        "미드솔",
        "함박",
        "스테이크",
        "고기",
        "소스",

        # 특정 플랫폼
        "instagram",
        "인스타",
        "인스타그램",
        "baemin",
        "배민",

        # 내부 시스템 용어
        "faster",
        "자동추천",
        "ai 추천",
    ]

    reusable_patterns = {
        "slogan_quality": [
            (
                ["슬로건", "카피", "간결", "기억", "길"],
                "슬로건은 설명형 문장보다 짧고 기억하기 쉬운 "
                "핵심 카피로 작성하세요.",
            ),
        ],

        "strategy_alignment": [
            (
                ["전략", "부합", "반영"],
                "선택된 광고 전략의 핵심 방향이 이미지 구성과 "
                "카피에 실제로 반영되도록 하세요.",
            ),
        ],

        "slogan_visual_alignment": [
            (
                ["텍스트", "가림", "제품", "여백", "배치"],
                "텍스트가 제품의 주요 영역을 가리지 않도록 "
                "충분한 여백을 확보하세요.",
            ),
            (
                ["텍스트", "비중", "크기", "과다"],
                "텍스트가 이미지에서 과도한 비중을 차지하지 "
                "않도록 시각적 우선순위를 조절하세요.",
            ),
        ],
    }

    result = {}

    for weak_area in weak_areas:
        area = weak_area["area"]

        area_feedback = classified_feedback.get(
            area,
            {},
        )

        texts = (
            area_feedback.get("issues", [])
            + area_feedback.get("improvements", [])
        )

        filtered_texts = []

        for text in texts:
            normalized = str(text).lower()

            if any(
                keyword.lower() in normalized
                for keyword in excluded_keywords
            ):
                continue

            filtered_texts.append(text)

        rules = []

        for keywords, rule in reusable_patterns.get(
            area,
            [],
        ):
            matched = any(
                any(
                    keyword.lower() in str(text).lower()
                    for keyword in keywords
                )
                for text in filtered_texts
            )

            if matched and rule not in rules:
                rules.append(rule)

            if len(rules) >= max_rules_per_area:
                break

        result[area] = {
            "score": weak_area["score"],
            "rules": rules,
        }

    return result


def get_prompt_improvement_context(
    *,
    db: Session,
    limit: int = 20,
    min_evaluations: int = 10,
    threshold: float = 8.0,
) -> dict:
    """
    누적된 광고 평가를 기반으로 다음 생성 프롬프트에 사용할
    개선 컨텍스트를 반환합니다.

    충분한 평가 데이터가 쌓이지 않은 경우에는
    개선 규칙을 활성화하지 않습니다.
    """

    evaluation_context = build_evaluation_improvement_context(
        db=db,
        limit=limit,
    )

    evaluation_count = evaluation_context.get(
        "evaluation_count",
        0,
    )

    if evaluation_count < min_evaluations:
        return {
            "enabled": False,
            "evaluation_count": evaluation_count,
            "required_count": min_evaluations,
            "weak_areas": [],
            "rules": {},
        }

    weak_areas = identify_evaluation_weak_areas(
        evaluation_context=evaluation_context,
        threshold=threshold,
    )

    if not weak_areas:
        return {
            "enabled": False,
            "evaluation_count": evaluation_count,
            "required_count": min_evaluations,
            "weak_areas": [],
            "rules": {},
        }

    classified_feedback = classify_evaluation_feedback(
        evaluation_context=evaluation_context,
        weak_areas=weak_areas,
    )

    rules = build_prompt_improvement_rules(
        classified_feedback=classified_feedback,
        weak_areas=weak_areas,
    )

    # 실제 규칙이 하나라도 존재하는지 확인
    has_rules = any(
        data.get("rules")
        for data in rules.values()
    )

    return {
        "enabled": has_rules,
        "evaluation_count": evaluation_count,
        "required_count": min_evaluations,
        "weak_areas": weak_areas,
        "rules": rules,
    }